<Window x:Class="Background_Picker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Background_Picker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#0D1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="1.5*"/>
        </Grid.RowDefinitions>

        <!-- Popups-->
        <Popup Name="apiPopup" IsOpen="False" Height="150" Width="500">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Enter OpenAI API Key here (gets stored locally):" Width="400" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/>
                <PasswordBox Grid.Row="1" Name="apiBox" Width="400" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button Grid.Row="2" Content="Submit" Width="200" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center" Click="SubmitBtn_OnClick"/>
            </Grid>
        </Popup>

        <Popup Name="loadingPopup" IsOpen="False" Height="150" Width="500">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Preprocessing Images..." Width="400" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/>
                <TextBlock Grid.Row="1" Name="percentageText" Text="1% Done | (0/x)" Width="400" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/>
                <ProgressBar Grid.Row="2" Name="loadingBar" Minimum="0" Maximum="100" Value="1" Width="400" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>
        </Popup>

        <!-- Menu Bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="0.2*"/>
            </Grid.ColumnDefinitions>
            <Button Content="set API Key" Name="setApiKey" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Width="70" Click="setApiKey_OnClick"/>
            <TextBlock Grid.Column="1"  HorizontalAlignment="Center" TextWrapping="Wrap" Text="Background Picker" VerticalAlignment="Center" FontSize="32" Foreground="White"/>
            <Button Content="set Folder" Name="setFolder" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Width="70" Click="setFolder_OnClick"/>
        </Grid>

        <Rectangle Name="Seperator1" Grid.Row="1" Fill="White"/>

        <!-- Content Pane -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="Image1Btn" Tag=""  Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment= "Stretch" Margin="30, 30, 30, 30" Click="Image1Btn_OnClick">
                <Button.Background>
                    <ImageBrush ImageSource="/Data/placeholder.png" Stretch="UniformToFill"/>
                </Button.Background>
            </Button>

            <Button Name="Image2Btn" Tag="" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment= "Stretch" Margin="30, 30, 30, 30" Click="Image2Btn_OnClick">
                <Button.Background>
                    <ImageBrush ImageSource="/Data/placeholder.png" Stretch="UniformToFill"/>
                </Button.Background>
            </Button>

            <Button Name="Image3Btn" Tag="" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment= "Stretch" Margin="30, 30, 30, 30" Click="Image3Btn_OnClick">
                <Button.Background>
                    <ImageBrush ImageSource="/Data/placeholder.png" Stretch="UniformToFill"/>
                </Button.Background>
            </Button>
        </Grid>

        <Rectangle Name="Seperator2" Grid.Row="3" Fill="White"/>

        <!-- Bottom Pane -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="0.2*"/>
            </Grid.ColumnDefinitions>
            <Button Content="UploadImageBtn" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="30,30,30,30" AllowDrop="True" DragOver="UploadImageBtn_OnDragOver" Drop="UploadImageBtn_OnDrop" Click="UploadImageBtn_OnClick"/>
            <TextBox Name="InputBox" Grid.Column="1" TextWrapping="Wrap" Text="" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="30,30,30,30" TextChanged="InputBox_TextChanged"/>
            <Button Name="SendBtn" Content="SendBtn" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="30,30,30,30" Click="SendBtn_OnClick"/>

        </Grid>
    </Grid>
</Window>
