<Window x:Class="Background_Picker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Background_Picker"
        mc:Ignorable="d"
        Title="Background Picker" Height="720" Width="1280">
    <Grid Background="#0D1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="1.5*"/>
        </Grid.RowDefinitions>

        <!-- Overlays -->
        <Grid Name="apiOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="#AA000000" Panel.ZIndex="10">
            <Border Background="#1E2530" Width="460" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="8">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Set API Key" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" Width="24" Height="24"
                                Foreground="Red" Background="Transparent" BorderThickness="0"
                                FontWeight="Bold" Click="CloseApiOverlay_OnClick"/>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="Enter your OpenAI API Key (stored locally):" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <PasswordBox Grid.Row="2" Name="apiBox" Height="32" Margin="0,0,0,16"/>
                    <Button Grid.Row="3" Content="Submit" Height="32" HorizontalAlignment="Right" Width="120" Click="SubmitBtn_OnClick"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Name="loadingOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="#AA000000" Panel.ZIndex="10">
            <Border Background="#1E2530" Width="460" Height="160" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="8">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Preprocessing Images..." Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="1" Name="percentageText" Text="0% Done | (0/0)" Foreground="#AAAAAA" Margin="0,0,0,12"/>
                    <ProgressBar Grid.Row="2" Name="loadingBar" Minimum="0" Maximum="100" Value="0" Height="12"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Menu Bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="0.2*"/>
            </Grid.ColumnDefinitions>
            <Button Content="set API Key" Name="setApiKey" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Width="70" Click="SetApiKey_OnClick"/>
            <TextBlock Grid.Column="1"  HorizontalAlignment="Center" TextWrapping="Wrap" Text="Background Picker" VerticalAlignment="Center" FontSize="32" Foreground="White"/>
            <Button Content="set Folder" Name="setFolder" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Width="70" Click="SetFolder_OnClick"/>
        </Grid>

        <Rectangle Name="Seperator1" Grid.Row="1" Fill="White"/>

        <!-- Content Pane -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="Image1Btn" Tag=""  Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment= "Stretch" Margin="30, 30, 30, 30" Click="ImageBtn_OnClick">
                <Button.Background>
                    <ImageBrush ImageSource="/Data/placeholder.png" Stretch="UniformToFill"/>
                </Button.Background>
            </Button>

            <Button Name="Image2Btn" Tag="" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment= "Stretch" Margin="30, 30, 30, 30" Click="ImageBtn_OnClick">
                <Button.Background>
                    <ImageBrush ImageSource="/Data/placeholder.png" Stretch="UniformToFill"/>
                </Button.Background>
            </Button>

            <Button Name="Image3Btn" Tag="" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment= "Stretch" Margin="30, 30, 30, 30" Click="ImageBtn_OnClick">
                <Button.Background>
                    <ImageBrush ImageSource="/Data/placeholder.png" Stretch="UniformToFill"/>
                </Button.Background>
            </Button>
        </Grid>

        <Rectangle Name="Seperator2" Grid.Row="3" Fill="White"/>

        <!-- Bottom Pane -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="0.2*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Upload New Images" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="30,30,30,30" AllowDrop="True" DragOver="UploadImageBtn_OnDragOver" Drop="UploadImageBtn_OnDrop" Click="UploadImageBtn_OnClick"/>
            <TextBox Name="InputBox" Grid.Column="1" TextWrapping="Wrap" Text="" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="30,30,30,30"/>
            <Button Name="SendBtn" Content="Send Request" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="30,30,30,30" Click="SendBtn_OnClick"/>

        </Grid>
    </Grid>
</Window>
